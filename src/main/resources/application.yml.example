spring:
  application:
    name: assignment

  datasource:
    url: jdbc:mysql://localhost:3306/assignment
    username: {MySQL username}
    password: {MySQL password}
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQL8Dialect
        format_sql: true
    show-sql: true
